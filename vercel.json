{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "vercel-static",
  "installCommand": null,
  "headers": [
    {
      "source": "/api/requirements",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=300"
        }
      ]
    }
  ]
}
